# ===== Flask =====
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# Host/port for the dev server
HOST=127.0.0.1
PORT=5000

# ===== Database =====
# MySQL (default — the option you selected). Create the DB first:
#   CREATE DATABASE housing DEFAULT CHARACTER SET utf8mb4;
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/housing?charset=utf8mb4
#
# PostgreSQL alternative (also install psycopg2-binary):
# DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/housing
#
# If DATABASE_URL is left empty, the app falls back to a local SQLite file
# (backend/housing.db) so you can run it without a DB server.

# ===== CORS =====
# Comma-separated list of allowed front-end origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
